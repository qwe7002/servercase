<?xml version="1.0" encoding="UTF-8"?>
<!--
  Template. Replace with the real GoogleService-Info.plist downloaded from your
  Firebase project (Project settings -> Your apps -> iOS, bundle id
  com.servercase.app), saved as ServerCase/GoogleService-Info.plist. It is
  gitignored. Without it the app still runs; FCM push just stays off.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>API_KEY</key>
	<string>REPLACE_IOS_API_KEY</string>
	<key>GCM_SENDER_ID</key>
	<string>REPLACE_SENDER_ID</string>
	<key>BUNDLE_ID</key>
	<string>com.servercase.app</string>
	<key>PROJECT_ID</key>
	<string>REPLACE_PROJECT_ID</string>
	<key>GOOGLE_APP_ID</key>
	<string>1:REPLACE_SENDER_ID:ios:REPLACE_APP_ID</string>
	<key>IS_GCM_ENABLED</key>
	<true/>
</dict>
</plist>
