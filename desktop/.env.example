# FCM web push (optional). Copy to `.env` and fill in from your Firebase project
# (Project settings → General → Your apps → Web app config) plus the Web Push
# certificate key pair (Cloud Messaging → Web configuration → "Key pair").
# Leave unset to disable desktop push. See README → Push notifications.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
